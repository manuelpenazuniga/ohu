# =============================================================================
# Ohu — Riel B (x402) — oráculo de reputación pago-por-request.
# =============================================================================
# Lee por infra/.env.example para las vars comunes. Estas son específicas del
# riel B (x402) y viven aparte para subrayar que x402 NO toca el escrow (INV-4).

# --- Red objetivo (Testnet) -------------------------------------------------
CAIP2_CHAIN_ID=casper:casper-test
FACILITATOR_RPC_URL=https://node.testnet.casperlabs.io/rpc

# --- Token CEP-18 usado para pagar el riel B (NO es el OhuVault) ------------
# Hash de paquete (64 hex, con o sin prefijo `hash-`) de un token CEP-18 ya
# desplegado en Testnet, p.ej. WCSPR. Chequea en CSPR.cloud que NO sea el
# paquete del contrato `OhuVault` (escrow) — si coincide, loadX402Config lanza.
ASSET_PACKAGE=
ASSET_NAME=WCSPR
ASSET_SYMBOL=WCSPR
ASSET_VERSION=1
ASSET_DECIMALS=9

# --- Quién cobra por el oráculo (cuenta-hash 00-prefijo 66 hex) ------------
PAYEE_ADDRESS=

# Precio de un request al oráculo de reputación, formato money x402.
X402_PRICE=$0.001

# --- Facilitators ----------------------------------------------------------
# Hosteado (primario). Vacío => se usa solo el local.
FACILITATOR_HOSTED_URL=
# Local (fallback). Apunta a Testnet vía FACILITATOR_RPC_URL.
FACILITATOR_LOCAL_URL=http://localhost:4022
# API key opcional si el facilitator hosteado la exige.
FACILITATOR_API_KEY=

# Identidad on-chain del facilitator local (su propia cuenta Ed25519,
# independiente del contrato — invariante de agente). PEM fuera del repo.
FACILITATOR_PEM_PATH=
FACILITATOR_KEY_ALGO=ed25519
FACILITATOR_PAYMENT_MOTES=1000000000

# Puertos.
RESOURCE_PORT=4021
FACILITATOR_PORT=4022

# --- Cliente pagador (demo live) -------------------------------------------
SERVER_URL=http://localhost:4021
ENDPOINT_PATH=/reputation/acme-farm
# PEM Ed25519 del pagador (cuenta propia, policitada para pagos x402).
CLIENT_PRIVATE_KEY_PATH=
CLIENT_KEY_ALGO=ed25519
CLIENT_PREFER_NETWORK=casper:

# Centinela INV-4 (fail-closed, S4-a): package hash del OhuVault (64 hex, con
# o sin prefijo `hash-`). REQUERIDO en producción: si falta, loadX402Config lanza
# en entornos non-test (no se permite silenciar el centinela omitiéndolo). Si
# coincide con ASSET_PACKAGE, la carga del riel B falla a propósito.
#
# Escape solo para tests: vitest (NODE_ENV=test / VITEST=true) o el override
# OHU_X402_TEST_CONFIG=1 para scripts de dev previos al deploy del OhuVault.
OHU_VAULT_PACKAGE=

# =============================================================================
# Ohu — Riel A (escrow) — Enjambre Tesorería + Autorizador (P1-2)
# =============================================================================
# Estas variables son compartidas por los dos procesos del enjambre. Cada
# proceso carga SOLO su propia llave (INV-2: separación de capacidad).

# --- Red Casper Testnet ------------------------------------------------------
# URL RPC del nodo (ej. https://node.testnet.casper.network/rpc).
NODE_URL=
# URL SSE /events para la mejora event-driven (ej. https://events.testnet.casper.network/events).
ODRA_CASPER_LIVENET_EVENTS_URL=
# Nombre de la red (casper-test).
CHAIN_NAME=casper-test

# --- Identidad del OhuVault desplegado ---------------------------------------
# Package hash del OhuVault (formato hash-<64hex>; se normaliza a 64 hex).
OHUVAULT_PACKAGE_HASH=
# Ventana de atestación en milisegundos.
OHUVAULT_ATTESTATION_WINDOW_MS=300000

# --- Llave operator (Tesorería — SOLO evaluate_lote, no mueve capital) -------
# PEM Ed25519 del operator. Fuera del repo (nunca commitear).
OPERATOR_SECRET_KEY_PATH=
# Cuenta-hash del operator para logging de identidad (66 hex, prefijo 00).
OHUVAULT_OPERATOR_ACCOUNT_HASH=

# --- Llave admin (Autorizador — release_to_producer / settle_failure) --------
# PEM Ed25519 del admin. Fuera del repo (nunca commitear).
ADMIN_SECRET_KEY_PATH=
# Cuenta-hash del admin para logging de identidad (66 hex, prefijo 00).
OHUVAULT_ADMIN_ACCOUNT_HASH=

# --- Parámetros del enjambre -------------------------------------------------
# Intervalo de sondeo entre reintentos (ms, default 15000).
SWARM_POLL_INTERVAL_MS=15000
# Archivo de log JSONL (default agents/.swarm-log.jsonl).
SWARM_LOG_FILE=agents/.swarm-log.jsonl
# Lotes objetivo como CSV (ej. "1,2,3"). Alternativa a --lote por CLI.
SWARM_TARGET_LOTES=
# Delay inicial del autorizador para evitar tx prematuras (ms, default 0).
SWARM_AUTORIZADOR_START_DELAY_MS=0
# Motos de gas por transacción. release_to_producer/settle_failure hacen
# transferencias (purse→producer + prima al pool) y consumen ~3 CSPR: con 3 CSPR
# de límite dan "Out of gas". 8 CSPR cubre settlement con margen (evaluate_lote,
# más barato, paga de más pero funciona). Verificado on-chain en el E2E de P1-2.
TX_PAYMENT_MOTES=8000000000