{
  "name": "@ohu/agents",
  "version": "0.1.0",
  "type": "module",
  "description": "Ohu off-chain agents (TypeScript + casper-js-sdk)",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "serve:resource": "tsx --env-file=../../.env src/x402/serve-resource.ts",
    "serve:facilitator": "tsx --env-file=../../.env src/x402/serve-facilitator.ts",
    "pay:get": "tsx --env-file=../../.env src/x402/pay.ts",
    "agent:tesoreria": "tsx --env-file=../.env src/tesoreria/index.ts",
    "agent:autorizador": "tsx --env-file=../.env src/autorizador/index.ts"
  },
  "dependencies": {
    "@make-software/casper-x402": "^1.0.0",
    "@x402/core": "^2.16.0",
    "@x402/express": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "casper-js-sdk": "5.0.12",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}