# Infra / deploy config — copy to repo root as `.env` and fill secrets.
# DO NOT commit `.env`; it is ignored by git.

# Casper Testnet RPC endpoint
NODE_URL=https://node.testnet.casperlabs.io/rpc

# Casper chain name for testnet
CHAIN_NAME=casper-test

# Ed25519 secret key PEM files for the on-chain identities.
# Leave empty in this template; point to local files outside the repo.
ADMIN_SECRET_KEY_PATH=
OPERATOR_SECRET_KEY_PATH=
DEPLOYER_SECRET_KEY_PATH=

# Optional: CSPR.cloud API key for event indexing / monitoring.
CSPRCLOUD_API_KEY=
