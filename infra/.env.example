# Infra / deploy config — copy to repo root as `.env` and fill secrets.
# DO NOT commit `.env`; it is ignored by git.

# Casper Testnet RPC endpoint
NODE_URL=https://node.testnet.casperlabs.io/rpc

# Casper chain name for testnet
CHAIN_NAME=casper-test

# Ed25519 secret key PEM files for the on-chain identities.
# Leave empty in this template; point to local files outside the repo.
ADMIN_SECRET_KEY_PATH=
OPERATOR_SECRET_KEY_PATH=
DEPLOYER_SECRET_KEY_PATH=

# Optional: CSPR.cloud API key for event indexing / monitoring.
CSPRCLOUD_API_KEY=

# -----------------------------------------------------------------------------
# S2 — Multisig nativo de la cuenta admin (capa 2 de INV-1).
# Ver infra/scripts/setup_admin_account.sh para el detalle del plan de pesos.
# -----------------------------------------------------------------------------

# Plan de pesos / thresholds (defaults seguros si se dejan vacíos).
DEPLOYMENT_THRESHOLD=3
KEY_MANAGEMENT_THRESHOLD=4
APPROVER_WEIGHT=1

# Claves públicas (hex) de los co-firmantes nativos de la cuenta admin,
# separadas por espacio. Se añaden como associated keys (peso APPROVER_WEIGHT).
# Genéralas con: casper-client keygen <dir>  y lee <dir>/public_key_hex
APPROVER_PUBLIC_KEYS_HEX=

# Path a un WASM de gestión de claves que exponga:
#   entry point `add_key`        (args: public_key:PublicKey, weight:u8)
#   entry point `set_thresholds` (args: deployment_threshold:u8, key_management_threshold:u8)
# y llame a las host functions add_associated_key / set_threshold del sistema.
# TODO(audit): proveer uno de referencia o construirlo en contracts/.
KEYS_MANAGER_WASM=

# -----------------------------------------------------------------------------
# S2 — Parámetros de inicialización de OhuVault (init args).
#   admin               = cuenta que ejecuta releases grandes (caller==admin)
#   operator            = cuenta del agente; solo llama route_micropayment
#   approvers           = firmantes M-de-N del contrato (lista de account-hash)
#   required_approvals  = M (aprobaciones distintas requeridas para execute)
#   micropayment_cap    = tope de motes por llamada a route_micropayment
# El script de deploy los convierte en runtime args del init.
# -----------------------------------------------------------------------------
OHUVAULT_REQUIRED_APPROVALS=2
# 1 CSPR = 1_000_000_000 motes
OHUVAULT_MICROPAYMENT_CAP_MOTES=1000000000
# Account hashes (account-hash-...) de admin, operator y approvers, separados
# por espacio. Se derivan de las claves públicas vía `casper-client account-address`.
OHUVAULT_ADMIN_ACCOUNT_HASH=
OHUVAULT_OPERATOR_ACCOUNT_HASH=
OHUVAULT_APPROVER_ACCOUNT_HASHES=

# -----------------------------------------------------------------------------
# W1-1 — Parámetros de init de OhuVault (continuación).
# -----------------------------------------------------------------------------

# Tope acumulado de motes por ventana de epoch para route_micropayment (INV-1).
OHUVAULT_EPOCH_CAP_MOTES=5000000000
# Ventana del epoch en milisegundos.
OHUVAULT_EPOCH_WINDOW_MS=3600000
# Chain ID para domain separation en atestaciones (fix #4).
# Casper Testnet chain_id = 0 (placeholder; consultar docs de Casper).
OHUVAULT_CHAIN_ID=0

# -----------------------------------------------------------------------------
# W2-1 — Disparador paramétrico de lote.
# -----------------------------------------------------------------------------

# Umbral de no-recepción en basis points (p.ej. 6000 = 60%).
# Si negative_shares * 10000 >= funded * quorum_fail_bps, el lote es EVAL_FAIL.
OHUVAULT_QUORUM_FAIL_BPS=6000
# Ventana de atestación en ms tras FUNDED. 60000 = 1 min (corto para E2E;
# en prod se recomienda 86_400_000 = 24h).
OHUVAULT_ATTESTATION_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# W2-3 — MutualPool integration.
# -----------------------------------------------------------------------------

# Prima en basis points cobrada al producer en release feliz.
# 50 = 0.5%.
OHUVAULT_PREMIUM_BPS=50
# Target de indemnización en basis points sobre funded.
# 8000 = 80%. El bono del producer debe ser >= target (C-1).
OHUVAULT_INDEMNITY_TARGET_BPS=8000

# -----------------------------------------------------------------------------
# W2-4 — Deploy / E2E tooling.
# -----------------------------------------------------------------------------

# Package hash del OhuVault desplegado (se completa tras el primer deploy).
OHUVAULT_PACKAGE_HASH=
# Package hash del MutualPool desplegado (se completa tras el primer deploy).
MUTUALPOOL_PACKAGE_HASH=

# Indice de la clave del admin en ODRA_CASPER_LIVENET_KEY_*.
# 0 = primary key (ODRA_CASPER_LIVENET_SECRET_KEY_PATH),
# 1 = ODRA_CASPER_LIVENET_KEY_1, etc.
OHUVAULT_ADMIN_KEY_INDEX=1

# Path al secret key PEM del buyer para firmar atestaciones off-chain (E2E).
# Por default, se usa ODRA_CASPER_LIVENET_SECRET_KEY_PATH (indice 0).
BUYER_SECRET_KEY_PATH=

